{
  "name": "form-rescue",
  "version": "1.0.0",
  "description": "An intelligent, zero-dependency auto-saver for HTML forms.",
  "main": "dist/rescue.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild index.ts --bundle --minify --format=iife --global-name=Rescue --outfile=dist/rescue.min.js && tsc --emitDeclarationOnly",
    "dev": "esbuild index.ts --bundle --format=iife --global-name=Rescue --outfile=dist/rescue.js --watch",
    "start": "npm run dev",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/form-rescue.git"
  },
  "keywords": ["form-rescue", "auto-save", "drafts"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
