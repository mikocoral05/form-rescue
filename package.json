{
  "name": "@mikael_tenshio/form-rescue",
  "version": "1.0.13",
  "description": "An intelligent, zero-dependency auto-saver for HTML forms.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "unpkg": "./dist/rescue.min.js",
  "jsdelivr": "./dist/rescue.min.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild index.ts --bundle --format=esm --platform=browser --outfile=dist/index.mjs && esbuild index.ts --bundle --format=cjs --platform=browser --outfile=dist/index.cjs && esbuild browser.ts --bundle --format=iife --outfile=dist/rescue.js && esbuild browser.ts --bundle --minify --format=iife --outfile=dist/rescue.min.js && tsc --emitDeclarationOnly",
    "dev": "esbuild browser.ts --bundle --format=iife --outfile=dist/rescue.js --watch",
    "start": "npm run dev",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run test && npm run build",
    "prepack": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikocoral05/form-rescue.git"
  },
  "keywords": [
    "form-rescue",
    "auto-save",
    "drafts"
  ],
  "author": "",
  "funding": [
    "https://ko-fi.com/mikaeltenshio",
    "https://buymeacoffee.com/mikaeltenshio"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^29.5.12",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
